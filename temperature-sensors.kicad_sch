	(text "nRF52840 ADCs are 12 bit\n4096 steps, i.e. 0.0008V steps\n\na difference of 1k in\nthermistor impedance is a 0.003V step"
		(exclude_from_sim no)
		(at 59.69 189.738 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ce7e070a-658e-4517-ae14-c34d74ccb050")
	)
	(text "CONN_BATT: direct battery connection\n+BATT: battery power rail, only available when VBUS is disconnected\nVDD: the actual power rail the components use. 3.3V when on USB, +BATT when on battery\n\nVBUS_CONNECTED: high (VBUS) when VBUS is connected, otherwise pulled to GND\n(PMOSes are +BATT in, VBUS > +BATT so it shouldn't matter)\n\nENABLE_3V3_ON_BATT: high (CONN_BATT) when 3.3V on BATT is enabled, otherwise pulled to GND\nDISABLE_3V3_ON_BATT: inverse of ENABLE_3V3_ON_BATT"
		(exclude_from_sim no)
		(at 107.696 216.154 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d8984767-28b8-4203-b538-297570f12cd3")
	)
